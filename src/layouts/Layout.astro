---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: string;
}

const {
	title = 'DGBACKERY&CAKE - Repostería Artesanal y Pan Fresco',
	description = 'Tortas personalizadas, pan artesanal y repostería de calidad. Hacemos realidad tus momentos especiales con sabor y dedicación.',
	image = '/og-image.jpg',
	type = 'website'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="repostería, tortas, pan artesanal, pasteles, postres, pedidos personalizados, cumpleaños, eventos, DGBACKERY, repostería casera" />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site)} />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:site_name" content="DGBACKERY&CAKE" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.site)} />
		
		<!-- Preconnect to external domains -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<!-- Google Fonts - L'Artisan Crème Design System -->
		<link href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		
		<!-- Google tag (gtag.js) -->
		<script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-4HDKR04H89"></script>
		<script type="text/partytown">
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-4HDKR04H89');
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	@tailwind base;
	@tailwind components;
	@tailwind utilities;
	
	@layer base {
		:root {
			/* L'Artisan Crème Design System - Colors */
			--color-surface: #fff8ef;
			--color-surface-bright: #fff8ef;
			--color-surface-container: #f5edde;
			--color-surface-container-low: #fbf3e4;
			--color-surface-container-high: #efe7d9;
			--color-surface-container-highest: #e9e2d3;
			--color-surface-container-lowest: #ffffff;
			
			--color-primary: #b02c32;
			--color-primary-container: #ffc8c5;
			--color-on-primary: #ffffff;
			--color-on-primary-container: #ad2a30;
			
			--color-secondary: #7c572e;
			--color-secondary-container: #fecb98;
			--color-on-secondary: #ffffff;
			--color-on-secondary-container: #79542b;
			
			--color-tertiary: #7c5730;
			--color-tertiary-container: #fecc9c;
			--color-on-tertiary: #ffffff;
			
			--color-outline: #82756a;
			--color-outline-variant: #d4c4b7;
			
			--color-on-surface: #1e1b13;
			--color-on-surface-variant: #50453b;
			
			/* Brand Colors */
			--color-brand-peach: #ffcc99;
			--color-brand-coral: #ff6666;
			--color-brand-cream: #fff8ef;
		}
		
		*,
		*::before,
		*::after {
			box-sizing: border-box;
		}
		
		html {
			scroll-behavior: smooth;
		}
		
		html,
		body {
			@apply m-0 p-0 w-full min-h-full;
			font-family: 'Manrope', system-ui, sans-serif;
			color: var(--color-on-surface);
			background-color: var(--color-surface);
			-webkit-font-smoothing: antialiased;
			-moz-osx-font-smoothing: grayscale;
			line-height: 1.6;
		}
		
		/* Editorial Typography */
		h1, h2, h3, h4, h5, h6 {
			font-family: 'Noto Serif', serif;
			font-weight: 600;
			margin: 0;
			line-height: 1.2;
			color: var(--color-on-surface);
		}
		
		h1 {
			font-size: clamp(2.5rem, 5vw, 4rem);
			letter-spacing: -0.02em;
		}
		
		h2 {
			font-size: clamp(2rem, 4vw, 3rem);
			letter-spacing: -0.01em;
		}
		
		h3 {
			font-size: clamp(1.5rem, 3vw, 2rem);
		}
		
		p {
			margin: 0;
			color: var(--color-on-surface-variant);
		}
		
		a {
			color: inherit;
			text-decoration: none;
			transition: all 0.3s ease;
		}
		
		img {
			max-width: 100%;
			height: auto;
			display: block;
		}
		
		button {
			font-family: 'Manrope', system-ui, sans-serif;
			cursor: pointer;
			border: none;
			background: none;
		}
	}
	
	@layer components {
		/* Editorial Button Styles */
		.btn-primary {
			@apply inline-flex items-center justify-center px-8 py-4;
			background: linear-gradient(135deg, var(--color-brand-coral), #e55555);
			color: white;
			font-weight: 600;
			font-size: 0.95rem;
			letter-spacing: 0.025em;
			border-radius: 0.125rem;
			transition: all 0.3s ease;
			box-shadow: 0 4px 20px rgba(176, 44, 50, 0.2);
		}
		
		.btn-primary:hover {
			transform: translateY(-2px);
			box-shadow: 0 8px 30px rgba(176, 44, 50, 0.3);
		}
		
		.btn-secondary {
			@apply inline-flex items-center justify-center px-8 py-4;
			background: transparent;
			color: var(--color-secondary);
			font-weight: 600;
			font-size: 0.95rem;
			letter-spacing: 0.025em;
			border: 1px solid var(--color-outline-variant);
			border-radius: 0.125rem;
			transition: all 0.3s ease;
		}
		
		.btn-secondary:hover {
			background: var(--color-surface-container);
			border-color: var(--color-secondary);
		}
		
		/* Category Label Style */
		.category-label {
			font-family: 'Manrope', sans-serif;
			font-size: 0.75rem;
			font-weight: 600;
			letter-spacing: 0.15em;
			text-transform: uppercase;
			color: var(--color-secondary);
		}
		
		/* Section Container */
		.section-container {
			@apply w-full;
			padding-top: clamp(4rem, 8vw, 7rem);
			padding-bottom: clamp(4rem, 8vw, 7rem);
		}
		
		/* Card Shadow - Soft & Ambient */
		.card-shadow {
			box-shadow: 0 20px 80px rgba(80, 69, 59, 0.08);
		}
		
		.card-shadow-hover {
			box-shadow: 0 30px 100px rgba(80, 69, 59, 0.12);
		}
		
		/* Ghost Border */
		.ghost-border {
			border: 1px solid rgba(130, 117, 106, 0.15);
		}
		
		/* Glass Effect for Navigation */
		.glass-effect {
			background: rgba(255, 248, 239, 0.85);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
		}
	}
	
	@layer utilities {
		/* Editorial Spacing Scale */
		.editorial-spacing {
			padding-top: clamp(4rem, 8vw, 7rem);
			padding-bottom: clamp(4rem, 8vw, 7rem);
		}
		
		.text-balance {
			text-wrap: balance;
		}
	}
</style>
