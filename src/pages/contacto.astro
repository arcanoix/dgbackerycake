---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const contactMethods = [
  {
    icon: 'phone',
    title: 'Teléfono',
    value: '+58 412-8477968',
    subtitle: 'Lun - Sáb: 8:00 AM - 6:00 PM',
    link: 'tel:+584128477968',
    color: 'bg-[#b02c32]',
  },
  {
    icon: 'whatsapp',
    title: 'WhatsApp',
    value: '+58 412-8477968',
    subtitle: 'Respuesta rápida garantizada',
    link: 'https://wa.me/584128477968',
    external: true,
    color: 'bg-[#25D366]',
  },
  {
    icon: 'mail',
    title: 'Email',
    value: 'dgbakerycake@gmail.com',
    subtitle: 'Te respondemos en 24 horas',
    link: 'mailto:dgbakerycake@gmail.com',
    color: 'bg-[#7c572e]',
  },
];

const socialLinks = [
  {
    icon: 'instagram',
    title: 'Instagram',
    value: '@dgbackerycake',
    subtitle: 'Síguenos para ver nuestras creaciones',
    link: 'https://www.instagram.com/dgbackerycake',
    color: 'bg-gradient-to-br from-[#f09433] via-[#e6683c] to-[#bc1888]',
  },
  {
    icon: 'tiktok',
    title: 'TikTok',
    value: '@dgbackerycake',
    subtitle: 'Videos de nuestro proceso',
    link: 'https://www.tiktok.com/@dgbackerycake',
    color: 'bg-[#1e1b13]',
  },
  {
    icon: 'facebook',
    title: 'Facebook',
    value: 'DGBACKERY&CAKE',
    subtitle: 'Síguenos en Facebook',
    link: 'https://www.facebook.com/profile.php?id=100090394729895',
    color: 'bg-[#1877F2]',
  },
];

const faqItems = [
  {
    question: '¿Con cuánta anticipación debo hacer mi pedido?',
    answer: 'Recomendamos hacer pedidos de tortas personalizadas con al menos 3-5 días de anticipación. Para pedidos más elaborados, sugerimos 1-2 semanas.',
  },
  {
    question: '¿Hacen entregas a domicilio?',
    answer: 'Sí, ofrecemos servicio de entrega a domicilio. El costo varía según la distancia. Contáctanos para más detalles.',
  },
  {
    question: '¿Puedo personalizar completamente mi torta?',
    answer: '¡Por supuesto! Trabajamos contigo para crear el diseño exacto que deseas. Comparte tu idea y la haremos realidad.',
  },
  {
    question: '¿Ofrecen opciones sin gluten o veganas?',
    answer: 'Sí, podemos preparar productos especiales bajo pedido. Consulta disponibilidad y precios al contactarnos.',
  },
  {
    question: '¿Cuáles son las formas de pago?',
    answer: 'Aceptamos efectivo, transferencias bancarias y pago móvil. Se requiere un adelanto del 50% para confirmar pedidos personalizados.',
  },
  {
    question: '¿Puedo ver mi torta antes de la entrega?',
    answer: 'Te enviamos fotos del producto terminado antes de la entrega para tu aprobación y tranquilidad.',
  },
];

const icons = {
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>`,
  mail: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  tiktok: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>`,
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
};
---

<Layout 
	title="Contacto - DGBACKERY&CAKE"
	description="Contáctanos para hacer tu pedido o resolver cualquier duda. Estamos aquí para ayudarte a crear momentos dulces inolvidables."
>
	<Header />
	
	<main>
		<!-- Page Hero -->
		<section class="pt-32 lg:pt-40 pb-16 lg:pb-24 bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="max-w-3xl">
					<span class="category-label text-[#7c572e] mb-4 block">Contacto</span>
					<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-semibold text-[#1e1b13] mb-6">
						Hablemos de tu 
						<span class="text-[#b02c32]">idea</span>
					</h1>
					<p class="text-lg text-[#50453b] leading-relaxed">
						Estamos aquí para ayudarte. Cuéntanos qué necesitas y haremos realidad tu idea. Responde rápidamente para atender tus necesidades.
					</p>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
					
					<!-- Contact Methods -->
					<div>
						<span class="category-label text-[#7c572e] mb-4 block">Información de Contacto</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13] mb-6">
							Conecta con nosotros
						</h2>
						
						<div class="space-y-4 mb-8">
							{contactMethods.map((method) => (
								<a
									href={method.link}
									target={method.external ? '_blank' : undefined}
									rel={method.external ? 'noopener noreferrer' : undefined}
									class="group flex items-center gap-4 p-5 bg-[#f5edde] border border-[#d4c4b7]/20 transition-all duration-300 hover:shadow-lg"
								>
									<div class={`w-12 h-12 flex items-center justify-center text-white rounded-sm ${method.color} transition-transform duration-300 group-hover:scale-110`}
									set:html={icons[method.icon]} />
									<div class="flex-1">
										<div class="text-sm text-[#82756a] mb-1">{method.title}</div>
										<div class="font-semibold text-[#1e1b13]">{method.value}</div>
										<div class="text-xs text-[#50453b]">{method.subtitle}</div>
									</div>
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#82756a] transition-transform duration-300 group-hover:translate-x-1">
										<path d="M5 12h14M12 5l7 7-7 7"/>
									</svg>
								</a>
							))}
						</div>

						<!-- Social Links -->
						<div class="mb-8">
							<h3 class="font-serif text-xl font-semibold text-[#1e1b13] mb-4">Síguenos en redes</h3>
							<div class="flex gap-3">
								{socialLinks.map((social) => (
									<a
										href={social.link}
										target="_blank"
										rel="noopener noreferrer"
										class="group w-12 h-12 flex items-center justify-center text-white rounded-sm transition-transform duration-300 hover:scale-110"
										class:list={[social.color]}
										set:html={icons[social.icon]}
									/>
								))}
							</div>
						</div>

						<!-- Hours Card -->
						<div class="p-6 bg-[#1e1b13] text-white">
							<div class="flex items-center gap-3 mb-6">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#fecb98]">
									<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
								</svg>
								<h3 class="font-serif text-xl font-semibold">Horario de Atención</h3>
							</div>
							<div class="space-y-3">
								<div class="flex justify-between items-center pb-3 border-b border-[#50453b]/30">
									<span class="text-[#d4c4b7]">Lunes - Viernes</span>
									<span class="font-medium">8:00 - 18:00</span>
								</div>
								<div class="flex justify-between items-center pb-3 border-b border-[#50453b]/30">
									<span class="text-[#d4c4b7]">Sábado</span>
									<span class="font-medium">9:00 - 17:00</span>
								</div>
								<div class="flex justify-between items-center">
									<span class="text-[#d4c4b7]">Domingo</span>
									<span class="text-[#b02c32]">Cerrado</span>
								</div>
							</div>
						</div>
					</div>

					<!-- Contact Form -->
					<div class="lg:pl-8">
						<span class="category-label text-[#7c572e] mb-4 block">Formulario</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13] mb-6">
							Envíanos un mensaje
						</h2>
						
						<form id="contactForm" class="space-y-6">
							<div class="grid sm:grid-cols-2 gap-6">
								<div>
									<label for="name" class="block text-sm font-medium text-[#1e1b13] mb-2">Nombre completo *</label>
									<input
										type="text"
										id="name"
										name="name"
										required
										class="w-full px-4 py-3 bg-white border border-[#d4c4b7]/50 text-[#1e1b13] placeholder-[#82756a] focus:outline-none focus:border-[#b02c32] transition-colors"
										placeholder="Tu nombre"
									/>
								</div>
								<div>
									<label for="phone" class="block text-sm font-medium text-[#1e1b13] mb-2">Teléfono *</label>
									<input
										type="tel"
										id="phone"
										name="phone"
										required
										class="w-full px-4 py-3 bg-white border border-[#d4c4b7]/50 text-[#1e1b13] placeholder-[#82756a] focus:outline-none focus:border-[#b02c32] transition-colors"
										placeholder="+58 412-XXXXXXX"
									/>
								</div>
							</div>
							
							<div>
								<label for="subject" class="block text-sm font-medium text-[#1e1b13] mb-2">Asunto *</label>
								<select
									id="subject"
									name="subject"
									required
									class="w-full px-4 py-3 bg-white border border-[#d4c4b7]/50 text-[#1e1b13] focus:outline-none focus:border-[#b02c32] transition-colors"
								>
									<option value="">Selecciona un asunto</option>
									<option value="Torta Personalizada">Torta Personalizada</option>
									<option value="Pedido de Pan">Pedido de Pan</option>
									<option value="Evento Especial">Evento Especial</option>
									<option value="Consulta General">Consulta General</option>
								</select>
							</div>
							
							<div>
								<label for="message" class="block text-sm font-medium text-[#1e1b13] mb-2">Mensaje *</label>
								<textarea
									id="message"
									name="message"
									rows="5"
									required
									class="w-full px-4 py-3 bg-white border border-[#d4c4b7]/50 text-[#1e1b13] placeholder-[#82756a] focus:outline-none focus:border-[#b02c32] transition-colors resize-none"
									placeholder="Cuéntanos qué necesitas..."
								></textarea>
							</div>
							
							<button
								type="submit"
								class="w-full sm:w-auto btn-primary"
							>
								<span class="flex items-center justify-center gap-2">
									Enviar Mensaje
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
									</svg>
								</span>
							</button>
							
							<p class="text-sm text-[#82756a]">
								Al enviar, serás redirigido a WhatsApp. También puedes escribirnos directamente al <a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" class="text-[#b02c32] hover:underline">+58 412-8477968</a>
							</p>
						</form>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section class="section-container bg-[#f5edde]">
			<div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="text-center mb-16">
					<span class="category-label text-[#7c572e] mb-4 block">FAQ</span>
					<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-[#1e1b13] mb-4">
						Preguntas <span class="text-[#b02c32]">Frecuentes</span>
					</h2>
					<p class="text-[#50453b]">
						Respuestas a las dudas más comunes
					</p>
				</div>
				
				<div class="space-y-4">
					{faqItems.map((item) => (
						<div class="faq-item bg-[#fff8ef] border border-[#d4c4b7]/20">
							<button class="faq-trigger w-full flex items-center justify-between p-6 text-left">
								<span class="font-serif text-lg font-semibold text-[#1e1b13] pr-4">{item.question}</span>
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="faq-icon flex-shrink-0 text-[#b02c32] transition-transform duration-300">
									<path d="M6 9l6 6 6-6"/>
								</svg>
							</button>
							<div class="faq-content hidden px-6 pb-6">
								<p class="text-[#50453b] leading-relaxed">{item.answer}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>

<style>
	.faq-item {
		transition: all 0.3s ease;
	}
	
	.faq-item.active {
		box-shadow: 0 20px 80px rgba(80, 69, 59, 0.08);
	}
	
	.faq-item.active .faq-icon {
		transform: rotate(180deg);
	}
</style>

<script>
	// FAQ Accordion
	const faqItems = document.querySelectorAll('.faq-item');
	
	faqItems.forEach(item => {
		const trigger = item.querySelector('.faq-trigger');
		const content = item.querySelector('.faq-content');
		
		trigger?.addEventListener('click', () => {
			const isActive = item.classList.contains('active');
			
			// Close all items
			faqItems.forEach(otherItem => {
				otherItem.classList.remove('active');
				const otherContent = otherItem.querySelector('.faq-content');
				if (otherContent) {
					otherContent.classList.add('hidden');
				}
			});
			
			// Open clicked item if it wasn't active
			if (!isActive) {
				item.classList.add('active');
				content?.classList.remove('hidden');
			}
		});
	});

	// Contact Form
	const form = document.getElementById('contactForm');
	
	form?.addEventListener('submit', (e) => {
		e.preventDefault();
		
		const formData = new FormData(form);
		const name = formData.get('name');
		const phone = formData.get('phone');
		const subject = formData.get('subject');
		const message = formData.get('message');
		
		const whatsappMessage = `Hola! Mi nombre es ${name}.%0A%0AAsunto: ${subject}%0A%0A${message}%0A%0ATeléfono: ${phone}`;
		const whatsappUrl = `https://wa.me/584128477968?text=${whatsappMessage}`;
		
		window.open(whatsappUrl, '_blank');
		
		form.reset();
	});
</script>
