---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<Layout 
	title="Contacto - DGBACKERY&CAKE"
	description="Contáctanos para hacer tu pedido o resolver cualquier duda. Estamos aquí para ayudarte a crear momentos dulces inolvidables."
>
	<Header />
	
	<main>
		<section class="page-hero">
			<div class="container">
				<h1 class="page-title">Contáctanos</h1>
				<p class="page-description">
					Estamos aquí para ayudarte. Cuéntanos qué necesitas y haremos realidad tu idea.
				</p>
			</div>
		</section>

		<section class="contact-section">
			<div class="container">
				<div class="contact-grid">
					<div class="contact-info">
						<h2 class="section-title">Información de Contacto</h2>
						<p class="info-description">
							Puedes contactarnos a través de cualquiera de estos medios. 
							Respondemos rápidamente para atender tus necesidades.
						</p>
						
						<div class="contact-methods">
							<div class="contact-method">
								<div class="method-icon">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
									</svg>
								</div>
								<div class="method-content">
									<h3>Teléfono</h3>
									<p>+58 412-8477968</p>
									<small>Lun - Sáb: 8:00 AM - 6:00 PM</small>
								</div>
							</div>

							<div class="contact-method">
								<div class="method-icon whatsapp">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
										<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
									</svg>
								</div>
								<div class="method-content">
									<h3>WhatsApp</h3>
									<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer">
										+58 412-8477968
									</a>
									<small>Respuesta rápida garantizada</small>
								</div>
							</div>

							<div class="contact-method">
								<div class="method-icon">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
										<polyline points="22,6 12,13 2,6"></polyline>
									</svg>
								</div>
								<div class="method-content">
									<h3>Email</h3>
									<a href="mailto:info@dgbakerycake.com">dgbakerycake@gmail.com</a>
									<small>Te respondemos en 24 horas</small>
								</div>
							</div>

							<div class="contact-method">
								<div class="method-icon instagram">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
										<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
										<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
									</svg>
								</div>
								<div class="method-content">
									<h3>Instagram</h3>
									<a href="https://www.instagram.com/dgbackerycake" target="_blank" rel="noopener noreferrer">
										@dgbackerycake
									</a>
									<small>Síguenos para ver nuestras creaciones</small>
								</div>
							</div>

							<div class="contact-method">
								<div class="method-icon tiktok">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
									</svg>
								</div>
								<div class="method-content">
									<h3>TikTok</h3>
									<a href="https://www.tiktok.com/@dgbackerycake" target="_blank" rel="noopener noreferrer">
										@dgbackerycake
									</a>
									<small>Videos de nuestro proceso</small>
								</div>
							</div>

							<div class="contact-method">
								<div class="method-icon facebook">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
										<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
									</svg>
								</div>
								<div class="method-content">
									<h3>Facebook</h3>
									<a href="https://www.facebook.com/profile.php?id=100090394729895" target="_blank" rel="noopener noreferrer">
										DGBACKERY&CAKE
									</a>
									<small>Síguenos en Facebook</small>
								</div>
							</div>
						</div>

						<div class="hours-card">
							<h3>⏰ Horario de Atención</h3>
							<div class="hours-list">
								<div class="hour-item">
									<span>Lunes - Viernes</span>
									<span>8:00 AM - 6:00 PM</span>
								</div>
								<div class="hour-item">
									<span>Sábado</span>
									<span>9:00 AM - 5:00 PM</span>
								</div>
								<div class="hour-item">
									<span>Domingo</span>
									<span>Cerrado</span>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</section>

		<section class="faq-section">
			<div class="container">
				<h2 class="section-title centered">Preguntas Frecuentes</h2>
				<div class="faq-grid">
					<div class="faq-item">
						<h3>¿Con cuánta anticipación debo hacer mi pedido?</h3>
						<p>Recomendamos hacer pedidos de tortas personalizadas con al menos 3-5 días de anticipación. Para pedidos más elaborados, sugerimos 1-2 semanas.</p>
					</div>
					<div class="faq-item">
						<h3>¿Hacen entregas a domicilio?</h3>
						<p>Sí, ofrecemos servicio de entrega a domicilio. El costo varía según la distancia. Contáctanos para más detalles.</p>
					</div>
					<div class="faq-item">
						<h3>¿Puedo personalizar completamente mi torta?</h3>
						<p>¡Por supuesto! Trabajamos contigo para crear el diseño exacto que deseas. Comparte tu idea y la haremos realidad.</p>
					</div>
					<div class="faq-item">
						<h3>¿Ofrecen opciones sin gluten o veganas?</h3>
						<p>Sí, podemos preparar productos especiales bajo pedido. Consulta disponibilidad y precios al contactarnos.</p>
					</div>
					<div class="faq-item">
						<h3>¿Cuáles son las formas de pago?</h3>
						<p>Aceptamos efectivo, transferencias bancarias y pago móvil. Se requiere un adelanto del 50% para confirmar pedidos personalizados.</p>
					</div>
					<div class="faq-item">
						<h3>¿Puedo ver mi torta antes de la entrega?</h3>
						<p>Te enviamos fotos del producto terminado antes de la entrega para tu aprobación y tranquilidad.</p>
					</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>

<style>
	.page-hero {
		background: linear-gradient(135deg, #fef3f4 0%, #fff5f7 100%);
		padding: 5rem 2rem 3rem;
		text-align: center;
	}
	
	.container {
		max-width: 1200px;
		margin: 0 auto;
	}
	
	.page-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.page-description {
		font-size: 1.25rem;
		color: var(--color-text-light);
		max-width: 700px;
		margin: 0 auto;
		line-height: 1.8;
	}
	
	.contact-section {
		padding: 5rem 2rem;
	}
	
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
	}
	
	.section-title {
		font-size: 2rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.section-title.centered {
		text-align: center;
		font-size: 2.5rem;
		margin-bottom: 3rem;
	}
	
	.info-description,
	.form-description {
		color: var(--color-text-light);
		line-height: 1.6;
		margin-bottom: 2rem;
	}
	
	.contact-methods {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}
	
	.contact-method {
		display: flex;
		gap: 1.5rem;
		padding: 1.5rem;
		background: var(--color-bg-light);
		border-radius: var(--radius-md);
		transition: var(--transition);
	}
	
	.contact-method:hover {
		box-shadow: var(--shadow-md);
		transform: translateX(5px);
	}
	
	.method-icon {
		width: 50px;
		height: 50px;
		background: var(--color-primary);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	
	.method-icon.whatsapp {
		background: #25D366;
	}
	
	.method-icon.instagram {
		background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
	}
	
	.method-icon.tiktok {
		background: #000000;
	}
	
	.method-content h3 {
		font-size: 1.1rem;
		margin-bottom: 0.5rem;
		color: var(--color-text);
	}
	
	.method-content p,
	.method-content a {
		color: var(--color-text-light);
		margin-bottom: 0.25rem;
	}
	
	.method-content a {
		color: var(--color-primary);
		font-weight: 600;
	}
	
	.method-content a:hover {
		text-decoration: underline;
	}
	
	.method-content small {
		color: var(--color-text-light);
		font-size: 0.85rem;
	}
	
	.hours-card {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
		color: white;
		padding: 2rem;
		border-radius: var(--radius-lg);
		margin-top: 2rem;
	}
	
	.hours-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
	}
	
	.hours-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	
	.hour-item {
		display: flex;
		justify-content: space-between;
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.2);
	}
	
	.hour-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	
	.contact-form-container {
		background: white;
		padding: 2.5rem;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-lg);
	}
	
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	
	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}
	
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	
	.form-group label {
		font-weight: 600;
		color: var(--color-text);
		font-size: 0.95rem;
	}
	
	.form-group input,
	.form-group select,
	.form-group textarea {
		padding: 0.875rem 1rem;
		border: 2px solid var(--color-border);
		border-radius: var(--radius-md);
		font-family: inherit;
		font-size: 1rem;
		transition: var(--transition);
	}
	
	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 3px rgba(216, 51, 51, 0.1);
	}
	
	.form-group textarea {
		resize: vertical;
		min-height: 120px;
	}
	
	.submit-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem 2rem;
		background: var(--color-primary);
		color: white;
		border: none;
		border-radius: var(--radius-md);
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		transition: var(--transition);
		box-shadow: var(--shadow-md);
	}
	
	.submit-btn:hover {
		background: var(--color-primary-dark);
		transform: translateY(-2px);
		box-shadow: var(--shadow-lg);
	}
	
	.form-note {
		font-size: 0.9rem;
		color: var(--color-text-light);
		text-align: center;
		margin-top: 0.5rem;
	}
	
	.form-note a {
		color: var(--color-primary);
		font-weight: 600;
	}
	
	.faq-section {
		padding: 5rem 2rem;
		background: var(--color-bg-light);
	}
	
	.faq-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 2rem;
	}
	
	.faq-item {
		background: white;
		padding: 2rem;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
		transition: var(--transition);
	}
	
	.faq-item:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-lg);
	}
	
	.faq-item h3 {
		font-size: 1.1rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.faq-item p {
		color: var(--color-text-light);
		line-height: 1.6;
	}
	
	@media (max-width: 968px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
		
		.form-row {
			grid-template-columns: 1fr;
		}
	}
	
	@media (max-width: 768px) {
		.page-hero {
			padding: 3rem 1rem 2rem;
		}
		
		.page-title {
			font-size: 2rem;
		}
		
		.page-description {
			font-size: 1rem;
		}
		
		.contact-section {
			padding: 3rem 1rem;
		}
		
		.contact-form-container {
			padding: 1.5rem;
		}
		
		.faq-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const form = document.getElementById('contactForm') as HTMLFormElement;
	
	if (form) {
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			
			const formData = new FormData(form);
			const name = formData.get('name');
			const phone = formData.get('phone');
			const subject = formData.get('subject');
			const message = formData.get('message');
			
			const whatsappMessage = `Hola! Mi nombre es ${name}.%0A%0AAsunto: ${subject}%0A%0A${message}%0A%0ATeléfono: ${phone}`;
			const whatsappUrl = `https://wa.me/584128477968?text=${whatsappMessage}`;
			
			window.open(whatsappUrl, '_blank');
			
			form.reset();
		});
	}
</script>
