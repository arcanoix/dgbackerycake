---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { Image } from 'astro:assets';
import dgLogo from '../assets/image/dg-logo.jpg';
---

<Layout>
	<Header />
	
	<main>
		<section class="hero">
			<div class="hero-content">
				<div class="hero-text">
					<h1 class="hero-title">
						Endulzamos tus <span class="highlight">momentos especiales</span>
					</h1>
					<p class="hero-description">
						Repostería artesanal hecha con amor, dedicación y los mejores ingredientes. 
						Tortas personalizadas, pan fresco y postres que harán de tu celebración algo inolvidable.
					</p>
					<div class="hero-buttons">
						<a href="/productos" class="btn btn-primary">Ver Productos</a>
						<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
							</svg>
							Hacer Pedido
						</a>
					</div>
				</div>
				<div class="hero-image">
					<Image 
						src={dgLogo} 
						alt="DGBACKERY&CAKE - Repostería Artesanal" 
						width={500}
						height={500}
						loading="eager"
						fetchpriority="high"
						class="logo-hero"
					/>
				</div>
			</div>
		</section>

		<section class="features">
			<div class="container">
				<div class="features-grid">
					<div class="feature-card">
						<div class="feature-icon">🎂</div>
						<h3>Tortas Personalizadas</h3>
						<p>Diseños únicos adaptados a tu celebración especial</p>
					</div>
					<div class="feature-card">
						<div class="feature-icon">🍞</div>
						<h3>Pan Artesanal</h3>
						<p>Fresco todos los días, hecho con ingredientes naturales</p>
					</div>
					<div class="feature-card">
						<div class="feature-icon">⭐</div>
						<h3>Calidad Premium</h3>
						<p>Solo usamos los mejores ingredientes en cada receta</p>
					</div>
					<div class="feature-card">
						<div class="feature-icon">🚚</div>
						<h3>Entrega a Domicilio</h3>
						<p>Llevamos tus pedidos frescos hasta tu puerta</p>
					</div>
				</div>
			</div>
		</section>

		<section class="products-preview">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Nuestros Productos Destacados</h2>
					<p class="section-description">Descubre nuestras creaciones más populares</p>
				</div>
				<div class="products-grid">
					<ProductCard 
						title="Torta de Chocolate"
						description="Deliciosa torta de chocolate con relleno de ganache y cobertura de crema de mantequilla"
						image={dgLogo}
						price="Desde $25"
						category="Tortas"
					/>
					<ProductCard 
						title="Pan Artesanal"
						description="Pan fresco horneado diariamente con masa madre y ingredientes naturales"
						image={dgLogo}
						price="$3/unidad"
						category="Pan"
					/>
					<ProductCard 
						title="Cupcakes Personalizados"
						description="Cupcakes decorados especialmente para tu evento, disponibles en múltiples sabores"
						image={dgLogo}
						price="$2/unidad"
						category="Postres"
					/>
				</div>
				<div class="text-center">
					<a href="/productos" class="btn btn-primary">Ver Todos los Productos</a>
				</div>
			</div>
		</section>

		<section class="testimonials">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Lo que dicen nuestros clientes</h2>
					<p class="section-description">Testimonios reales de personas que han disfrutado nuestros productos</p>
				</div>
				<div class="testimonials-grid">
					<TestimonialCard 
						name="María González"
						text="La torta de cumpleaños que pedí superó todas mis expectativas. Deliciosa y hermosa. ¡Todos quedaron encantados!"
						rating={5}
					/>
					<TestimonialCard 
						name="Carlos Rodríguez"
						text="El pan artesanal es increíble, fresco y con un sabor único. Ahora es parte de mi desayuno diario."
						rating={5}
					/>
					<TestimonialCard 
						name="Ana Martínez"
						text="Excelente servicio y atención. Los cupcakes para mi boda fueron perfectos. Altamente recomendado."
						rating={5}
					/>
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<div class="cta-content">
					<h2 class="cta-title">¿Listo para hacer tu pedido?</h2>
					<p class="cta-description">Contáctanos por WhatsApp y cuéntanos qué necesitas. Estamos aquí para hacer realidad tus ideas.</p>
					<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" class="btn btn-white">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
						Contactar Ahora
					</a>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>

<style>
	.hero {
		background: linear-gradient(135deg, #fef3f4 0%, #fff5f7 100%);
		padding: 4rem 2rem;
		min-height: 80vh;
		display: flex;
		align-items: center;
	}
	
	.hero-content {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	
	.hero-title {
		font-size: 3.5rem;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		color: var(--color-text);
	}
	
	.highlight {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	
	.hero-description {
		font-size: 1.25rem;
		line-height: 1.8;
		color: var(--color-text-light);
		margin-bottom: 2rem;
	}
	
	.hero-buttons {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 2rem;
		border-radius: var(--radius-md);
		font-weight: 600;
		font-size: 1rem;
		transition: var(--transition);
		cursor: pointer;
		border: none;
	}
	
	.btn-primary {
		background: var(--color-primary);
		color: white;
		box-shadow: var(--shadow-md);
	}
	
	.btn-primary:hover {
		background: var(--color-primary-dark);
		transform: translateY(-2px);
		box-shadow: var(--shadow-lg);
	}
	
	.btn-secondary {
		background: white;
		color: var(--color-primary);
		border: 2px solid var(--color-primary);
	}
	
	.btn-secondary:hover {
		background: var(--color-primary);
		color: white;
		transform: translateY(-2px);
	}
	
	.btn-white {
		background: white;
		color: var(--color-primary);
		box-shadow: var(--shadow-lg);
	}
	
	.btn-white:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-xl);
	}
	
	.hero-image {
		display: flex;
		justify-content: center;
		align-items: center;
	}
	
	.logo-hero {
		border-radius: 50%;
		box-shadow: var(--shadow-xl);
		animation: float 3s ease-in-out infinite;
	}
	
	@keyframes float {
		0%, 100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-20px);
		}
	}
	
	.features {
		padding: 4rem 2rem;
		background: white;
	}
	
	.container {
		max-width: 1200px;
		margin: 0 auto;
	}
	
	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}
	
	.feature-card {
		text-align: center;
		padding: 2rem;
		border-radius: var(--radius-lg);
		background: var(--color-bg-light);
		transition: var(--transition);
	}
	
	.feature-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--shadow-lg);
	}
	
	.feature-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
	}
	
	.feature-card h3 {
		font-size: 1.25rem;
		margin-bottom: 0.75rem;
		color: var(--color-text);
	}
	
	.feature-card p {
		color: var(--color-text-light);
		line-height: 1.6;
	}
	
	.products-preview,
	.testimonials {
		padding: 4rem 2rem;
	}
	
	.products-preview {
		background: var(--color-bg-light);
	}
	
	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}
	
	.section-title {
		font-size: 2.5rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.section-description {
		font-size: 1.1rem;
		color: var(--color-text-light);
		max-width: 600px;
		margin: 0 auto;
	}
	
	.products-grid,
	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-bottom: 3rem;
	}
	
	.text-center {
		text-align: center;
	}
	
	.cta-section {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
		color: white;
		padding: 5rem 2rem;
		text-align: center;
	}
	
	.cta-content {
		max-width: 800px;
		margin: 0 auto;
	}
	
	.cta-title {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}
	
	.cta-description {
		font-size: 1.25rem;
		margin-bottom: 2rem;
		opacity: 0.95;
	}
	
	@media (max-width: 768px) {
		.hero {
			padding: 3rem 1rem;
			min-height: auto;
		}
		
		.hero-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		
		.hero-title {
			font-size: 2rem;
		}
		
		.hero-description {
			font-size: 1rem;
		}
		
		.hero-buttons {
			flex-direction: column;
		}
		
		.btn {
			width: 100%;
			justify-content: center;
		}
		
		.section-title {
			font-size: 1.75rem;
		}
		
		.cta-title {
			font-size: 1.75rem;
		}
		
		.products-grid,
		.testimonials-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
