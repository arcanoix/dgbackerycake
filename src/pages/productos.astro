---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import dgLogo from '../assets/image/dg-logo.jpg';

const categories = [
  { id: 'tortas', label: 'Tortas', count: 6 },
  { id: 'pan', label: 'Pan', count: 6 },
  { id: 'pasteles', label: 'Pasteles', count: 6 },
  { id: 'postres', label: 'Postres', count: 6 },
];

const products = {
  tortas: [
    { title: 'Torta de Chocolate Premium', description: 'Bizcocho de chocolate húmedo con relleno de ganache y cobertura de crema de mantequilla. Decoración personalizada.', price: 'Desde $55', image: dgLogo },
    { title: 'Torta de Vainilla Clásica', description: 'Suave bizcocho de vainilla con relleno de crema pastelera y frutas frescas. Perfecta para cualquier celebración.', price: 'Desde $50', image: dgLogo },
    { title: 'Torta Red Velvet', description: 'Delicioso bizcocho rojo aterciopelado con frosting de queso crema. Un clásico irresistible.', price: 'Desde $60', image: dgLogo },
    { title: 'Torta de Zanahoria', description: 'Bizcocho especiado con zanahoria, nueces y pasas. Cubierta con frosting de queso crema.', price: 'Desde $55', image: dgLogo },
    { title: 'Torta Tres Leches', description: 'Tradicional torta empapada en tres tipos de leche. Ligera, húmeda y deliciosa.', price: 'Desde $45', image: dgLogo },
    { title: 'Torta Temática Infantil', description: 'Diseños creativos para cumpleaños infantiles. Personajes, colores y sabores a tu elección.', price: 'Desde $70', image: dgLogo },
  ],
  pan: [
    { title: 'Pan de Masa Madre', description: 'Pan artesanal fermentado naturalmente. Corteza crujiente y miga esponjosa.', price: 'Desde $12', image: dgLogo },
    { title: 'Pan Integral', description: 'Pan saludable elaborado con harina integral 100%. Rico en fibra y nutrientes.', price: 'Desde $10', image: dgLogo },
    { title: 'Baguette Francesa', description: 'Crujiente por fuera, suave por dentro. Perfecta para acompañar tus comidas.', price: 'Desde $8', image: dgLogo },
    { title: 'Pan de Centeno', description: 'Pan denso y aromático con semillas de centeno. Ideal para sándwiches.', price: 'Desde $11', image: dgLogo },
    { title: 'Pan de Ajo', description: 'Pan suave con mantequilla de ajo y hierbas. Perfecto como acompañamiento.', price: 'Desde $9', image: dgLogo },
    { title: 'Focaccia', description: 'Pan italiano con aceite de oliva, romero y sal marina. Esponjoso y aromático.', price: 'Desde $13', image: dgLogo },
  ],
  pasteles: [
    { title: 'Cupcakes Gourmet', description: 'Cupcakes decorados con buttercream y toppings premium. Variedad de sabores disponibles.', price: 'Desde $25/dz', image: dgLogo },
    { title: 'Mini Cheesecakes', description: 'Cheesecake individual con base de galleta y cobertura de frutos rojos.', price: 'Desde $30/dz', image: dgLogo },
    { title: 'Brownies Premium', description: 'Brownies de chocolate intenso con nueces. Densos, húmedos y deliciosos.', price: 'Desde $20/dz', image: dgLogo },
    { title: 'Macarons Franceses', description: 'Delicados macarons en variedad de sabores y colores. Perfectos para regalar.', price: 'Desde $35/dz', image: dgLogo },
    { title: 'Tartaletas de Frutas', description: 'Tartaletas con crema pastelera y frutas frescas de temporada.', price: 'Desde $28/dz', image: dgLogo },
    { title: 'Alfajores Artesanales', description: 'Alfajores rellenos de dulce de leche y cubiertos con chocolate o azúcar glass.', price: 'Desde $22/dz', image: dgLogo },
  ],
  postres: [
    { title: 'Tiramisú Clásico', description: 'Postre italiano con capas de bizcocho, café y crema de mascarpone.', price: 'Desde $40', image: dgLogo },
    { title: 'Pie de Limón', description: 'Base crujiente con relleno cremoso de limón y merengue tostado.', price: 'Desde $35', image: dgLogo },
    { title: 'Mousse de Chocolate', description: 'Mousse ligero y aireado de chocolate belga. Pura indulgencia.', price: 'Desde $30', image: dgLogo },
    { title: 'Flan de Caramelo', description: 'Flan casero suave y cremoso con caramelo líquido. Receta tradicional.', price: 'Desde $25', image: dgLogo },
    { title: 'Pavlova', description: 'Merengue crujiente con crema batida y frutas frescas. Ligero y delicioso.', price: 'Desde $45', image: dgLogo },
    { title: 'Crème Brûlée', description: 'Natilla francesa con costra de azúcar caramelizada. Elegante y refinado.', price: 'Desde $38', image: dgLogo },
  ],
};
---

<Layout 
	title="Productos - DGBACKERY&CAKE"
	description="Descubre nuestra variedad de productos: tortas personalizadas, pan artesanal, pasteles y postres. Calidad y sabor garantizados."
>
	<Header />
	
	<main>
		<!-- Page Hero -->
		<section class="pt-32 lg:pt-40 pb-16 lg:pb-24 bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="max-w-3xl">
					<span class="category-label text-[#7c572e] mb-4 block">Catálogo</span>
					<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-semibold text-[#1e1b13] mb-6">
						Nuestros 
						<span class="text-[#b02c32]">Productos</span>
					</h1>
					<p class="text-lg text-[#50453b] leading-relaxed">
						Explora nuestra deliciosa selección de productos artesanales, elaborados con los mejores ingredientes y mucho amor. Cada creación es única y hecha a mano.
					</p>
				</div>
			</div>
		</section>

		<!-- Category Navigation -->
		<section class="sticky top-20 lg:top-24 z-30 bg-[#fff8ef] border-b border-[#d4c4b7]/30">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<CategoryFilter categories={categories} />
			</div>
		</section>

		<!-- Products Sections -->
		<section id="tortas" class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
					<div>
						<span class="category-label text-[#7c572e] mb-4 block">01</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13]">
							Tortas Personalizadas
						</h2>
					</div>
					<p class="text-[#50453b] lg:text-right lg:max-w-md">
						Diseños únicos para cada ocasión especial. Trabajamos contigo para crear la torta perfecta.
					</p>
				</div>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{products.tortas.map((product) => (
						<ProductCard 
							title={product.title}
							description={product.description}
							image={product.image}
							category="Tortas"
							price={product.price}
						/>
					))}
				</div>
			</div>
		</section>

		<section id="pan" class="section-container bg-[#f5edde]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
					<div>
						<span class="category-label text-[#7c572e] mb-4 block">02</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13]">
							Pan Artesanal
						</h2>
					</div>
					<p class="text-[#50453b] lg:text-right lg:max-w-md">
						Pan fresco horneado diariamente con ingredientes naturales y técnicas tradicionales.
					</p>
				</div>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{products.pan.map((product) => (
						<ProductCard 
							title={product.title}
							description={product.description}
							image={product.image}
							category="Pan"
							price={product.price}
						/>
					))}
				</div>
			</div>
		</section>

		<section id="pasteles" class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
					<div>
						<span class="category-label text-[#7c572e] mb-4 block">03</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13]">
							Pasteles y Cupcakes
						</h2>
					</div>
					<p class="text-[#50453b] lg:text-right lg:max-w-md">
						Pequeñas delicias perfectas para eventos, regalos o simplemente darte un gusto.
					</p>
				</div>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{products.pasteles.map((product) => (
						<ProductCard 
							title={product.title}
							description={product.description}
							image={product.image}
							category="Pasteles"
							price={product.price}
						/>
					))}
				</div>
			</div>
		</section>

		<section id="postres" class="section-container bg-[#f5edde]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
					<div>
						<span class="category-label text-[#7c572e] mb-4 block">04</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13]">
							Postres Especiales
						</h2>
					</div>
					<p class="text-[#50453b] lg:text-right lg:max-w-md">
						Postres elaborados para ocasiones especiales o para consentirte cualquier día.
					</p>
				</div>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					{products.postres.map((product) => (
						<ProductCard 
							title={product.title}
							description={product.description}
							image={product.image}
							category="Postres"
							price={product.price}
						/>
					))}
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 lg:py-32 bg-[#b02c32]">
			<div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
				<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-white mb-6">
					¿No encuentras lo que buscas?
				</h2>
				<p class="text-lg text-white/90 mb-10 max-w-2xl mx-auto">
					Podemos crear productos personalizados según tus necesidades. Contáctanos y cuéntanos tu idea.
				</p>
				<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" 
				   class="inline-flex items-center justify-center gap-3 px-10 py-5 text-lg font-semibold text-[#b02c32] bg-white rounded-sm shadow-2xl hover:shadow-3xl hover:scale-105 transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
					</svg>
					Solicitar Pedido Personalizado
				</a>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>
