---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import dgLogo from '../assets/image/dg-logo.jpg';
---

<Layout 
	title="Productos - DGBACKERY&CAKE"
	description="Descubre nuestra variedad de productos: tortas personalizadas, pan artesanal, pasteles y postres. Calidad y sabor garantizados."
>
	<Header />
	
	<main>
		<section class="page-hero">
			<div class="container">
				<h1 class="page-title">Nuestros Productos</h1>
				<p class="page-description">
					Explora nuestra deliciosa selección de productos artesanales, 
					elaborados con los mejores ingredientes y mucho amor.
				</p>
			</div>
		</section>

		<section class="products-section" id="tortas">
			<div class="container">
				<div class="category-header">
					<h2 class="category-title">🎂 Tortas Personalizadas</h2>
					<p class="category-description">
						Diseños únicos para cada ocasión especial. Trabajamos contigo para crear la torta perfecta.
					</p>
				</div>
				<div class="products-grid">
					<ProductCard 
						title="Torta de Chocolate Premium"
						description="Bizcocho de chocolate húmedo con relleno de ganache y cobertura de crema de mantequilla. Decoración personalizada."
						image={dgLogo}
						price="Desde $25"
						category="Tortas"
					/>
					<ProductCard 
						title="Torta de Vainilla Clásica"
						description="Suave bizcocho de vainilla con relleno de crema pastelera y frutas frescas. Perfecta para cualquier celebración."
						image={dgLogo}
						price="Desde $22"
						category="Tortas"
					/>
					<ProductCard 
						title="Torta Red Velvet"
						description="Delicioso bizcocho rojo aterciopelado con frosting de queso crema. Un clásico irresistible."
						image={dgLogo}
						price="Desde $28"
						category="Tortas"
					/>
					<ProductCard 
						title="Torta de Zanahoria"
						description="Bizcocho especiado con zanahoria, nueces y pasas. Cubierta con frosting de queso crema."
						image={dgLogo}
						price="Desde $24"
						category="Tortas"
					/>
					<ProductCard 
						title="Torta Tres Leches"
						description="Tradicional torta empapada en tres tipos de leche. Ligera, húmeda y deliciosa."
						image={dgLogo}
						price="Desde $26"
						category="Tortas"
					/>
					<ProductCard 
						title="Torta Temática Infantil"
						description="Diseños creativos para cumpleaños infantiles. Personajes, colores y sabores a tu elección."
						image={dgLogo}
						price="Desde $35"
						category="Tortas"
					/>
				</div>
			</div>
		</section>

		<section class="products-section alt" id="pan">
			<div class="container">
				<div class="category-header">
					<h2 class="category-title">🍞 Pan Artesanal</h2>
					<p class="category-description">
						Pan fresco horneado diariamente con ingredientes naturales y técnicas tradicionales.
					</p>
				</div>
				<div class="products-grid">
					<ProductCard 
						title="Pan de Masa Madre"
						description="Pan artesanal fermentado naturalmente. Corteza crujiente y miga esponjosa."
						image={dgLogo}
						price="$4/unidad"
						category="Pan"
					/>
					<ProductCard 
						title="Pan Integral"
						description="Pan saludable elaborado con harina integral 100%. Rico en fibra y nutrientes."
						image={dgLogo}
						price="$3.50/unidad"
						category="Pan"
					/>
					<ProductCard 
						title="Baguette Francesa"
						description="Crujiente por fuera, suave por dentro. Perfecta para acompañar tus comidas."
						image={dgLogo}
						price="$2.50/unidad"
						category="Pan"
					/>
					<ProductCard 
						title="Pan de Centeno"
						description="Pan denso y aromático con semillas de centeno. Ideal para sándwiches."
						image={dgLogo}
						price="$4.50/unidad"
						category="Pan"
					/>
					<ProductCard 
						title="Pan de Ajo"
						description="Pan suave con mantequilla de ajo y hierbas. Perfecto como acompañamiento."
						image={dgLogo}
						price="$3/unidad"
						category="Pan"
					/>
					<ProductCard 
						title="Focaccia"
						description="Pan italiano con aceite de oliva, romero y sal marina. Esponjoso y aromático."
						image={dgLogo}
						price="$5/unidad"
						category="Pan"
					/>
				</div>
			</div>
		</section>

		<section class="products-section" id="pasteles">
			<div class="container">
				<div class="category-header">
					<h2 class="category-title">🧁 Pasteles y Cupcakes</h2>
					<p class="category-description">
						Pequeñas delicias perfectas para eventos, regalos o simplemente darte un gusto.
					</p>
				</div>
				<div class="products-grid">
					<ProductCard 
						title="Cupcakes Gourmet"
						description="Cupcakes decorados con buttercream y toppings premium. Variedad de sabores disponibles."
						image={dgLogo}
						price="$2.50/unidad"
						category="Pasteles"
					/>
					<ProductCard 
						title="Mini Cheesecakes"
						description="Cheesecake individual con base de galleta y cobertura de frutos rojos."
						image={dgLogo}
						price="$3/unidad"
						category="Pasteles"
					/>
					<ProductCard 
						title="Brownies Premium"
						description="Brownies de chocolate intenso con nueces. Densos, húmedos y deliciosos."
						image={dgLogo}
						price="$2/unidad"
						category="Pasteles"
					/>
					<ProductCard 
						title="Macarons Franceses"
						description="Delicados macarons en variedad de sabores y colores. Perfectos para regalar."
						image={dgLogo}
						price="$1.50/unidad"
						category="Pasteles"
					/>
					<ProductCard 
						title="Tartaletas de Frutas"
						description="Tartaletas con crema pastelera y frutas frescas de temporada."
						image={dgLogo}
						price="$3.50/unidad"
						category="Pasteles"
					/>
					<ProductCard 
						title="Alfajores Artesanales"
						description="Alfajores rellenos de dulce de leche y cubiertos con chocolate o azúcar glass."
						image={dgLogo}
						price="$1.80/unidad"
						category="Pasteles"
					/>
				</div>
			</div>
		</section>

		<section class="products-section alt" id="postres">
			<div class="container">
				<div class="category-header">
					<h2 class="category-title">🍰 Postres Especiales</h2>
					<p class="category-description">
						Postres elaborados para ocasiones especiales o para consentirte cualquier día.
					</p>
				</div>
				<div class="products-grid">
					<ProductCard 
						title="Tiramisú Clásico"
						description="Postre italiano con capas de bizcocho, café y crema de mascarpone."
						image={dgLogo}
						price="$6/porción"
						category="Postres"
					/>
					<ProductCard 
						title="Pie de Limón"
						description="Base crujiente con relleno cremoso de limón y merengue tostado."
						image={dgLogo}
						price="$18/pie completo"
						category="Postres"
					/>
					<ProductCard 
						title="Mousse de Chocolate"
						description="Mousse ligero y aireado de chocolate belga. Pura indulgencia."
						image={dgLogo}
						price="$5/porción"
						category="Postres"
					/>
					<ProductCard 
						title="Flan de Caramelo"
						description="Flan casero suave y cremoso con caramelo líquido. Receta tradicional."
						image={dgLogo}
						price="$4/porción"
						category="Postres"
					/>
					<ProductCard 
						title="Pavlova"
						description="Merengue crujiente con crema batida y frutas frescas. Ligero y delicioso."
						image={dgLogo}
						price="$20/porción grande"
						category="Postres"
					/>
					<ProductCard 
						title="Crème Brûlée"
						description="Natilla francesa con costra de azúcar caramelizada. Elegante y refinado."
						image={dgLogo}
						price="$5.50/porción"
						category="Postres"
					/>
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<div class="cta-content">
					<h2 class="cta-title">¿No encuentras lo que buscas?</h2>
					<p class="cta-description">
						Podemos crear productos personalizados según tus necesidades. 
						Contáctanos y cuéntanos tu idea.
					</p>
					<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" class="btn btn-white">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
						Solicitar Pedido Personalizado
					</a>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>

<style>
	.page-hero {
		background: linear-gradient(135deg, #fef3f4 0%, #fff5f7 100%);
		padding: 5rem 2rem 3rem;
		text-align: center;
	}
	
	.container {
		max-width: 1200px;
		margin: 0 auto;
	}
	
	.page-title {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.page-description {
		font-size: 1.25rem;
		color: var(--color-text-light);
		max-width: 700px;
		margin: 0 auto;
		line-height: 1.8;
	}
	
	.products-section {
		padding: 4rem 2rem;
	}
	
	.products-section.alt {
		background: var(--color-bg-light);
	}
	
	.category-header {
		text-align: center;
		margin-bottom: 3rem;
	}
	
	.category-title {
		font-size: 2.5rem;
		margin-bottom: 1rem;
		color: var(--color-text);
	}
	
	.category-description {
		font-size: 1.1rem;
		color: var(--color-text-light);
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.6;
	}
	
	.products-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2rem;
		margin-bottom: 2rem;
	}
	
	.cta-section {
		background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
		color: white;
		padding: 5rem 2rem;
		text-align: center;
	}
	
	.cta-content {
		max-width: 800px;
		margin: 0 auto;
	}
	
	.cta-title {
		font-size: 2.5rem;
		margin-bottom: 1rem;
	}
	
	.cta-description {
		font-size: 1.25rem;
		margin-bottom: 2rem;
		opacity: 0.95;
		line-height: 1.6;
	}
	
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 2rem;
		border-radius: var(--radius-md);
		font-weight: 600;
		font-size: 1rem;
		transition: var(--transition);
		cursor: pointer;
		border: none;
	}
	
	.btn-white {
		background: white;
		color: var(--color-primary);
		box-shadow: var(--shadow-lg);
	}
	
	.btn-white:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-xl);
	}
	
	@media (max-width: 768px) {
		.page-hero {
			padding: 3rem 1rem 2rem;
		}
		
		.page-title {
			font-size: 2rem;
		}
		
		.page-description {
			font-size: 1rem;
		}
		
		.category-title {
			font-size: 1.75rem;
		}
		
		.products-grid {
			grid-template-columns: 1fr;
		}
		
		.cta-title {
			font-size: 1.75rem;
		}
		
		.cta-description {
			font-size: 1rem;
		}
	}
</style>
