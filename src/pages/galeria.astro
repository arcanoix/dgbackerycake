---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { Image } from 'astro:assets';
import dgLogo from '../assets/image/dg-logo.jpg';

const galleryItems = [
  { category: 'tortas', title: 'Torta de Chocolate Premium', subtitle: 'Cumpleaños especial', image: dgLogo },
  { category: 'tortas', title: 'Torta Red Velvet', subtitle: 'Aniversario', image: dgLogo },
  { category: 'pan', title: 'Pan Artesanal Variado', subtitle: 'Horneado diario', image: dgLogo },
  { category: 'pasteles', title: 'Cupcakes Gourmet', subtitle: 'Baby shower', image: dgLogo },
  { category: 'tortas', title: 'Torta Temática Infantil', subtitle: 'Cumpleaños infantil', image: dgLogo },
  { category: 'postres', title: 'Macarons Franceses', subtitle: 'Mesa de postres', image: dgLogo },
  { category: 'pan', title: 'Baguette Francesa', subtitle: 'Pan fresco', image: dgLogo },
  { category: 'postres', title: 'Tiramisú Clásico', subtitle: 'Postre especial', image: dgLogo },
  { category: 'tortas', title: 'Torta de Vainilla', subtitle: 'Boda elegante', image: dgLogo },
  { category: 'pasteles', title: 'Brownies Premium', subtitle: 'Evento corporativo', image: dgLogo },
  { category: 'pan', title: 'Focaccia Italiana', subtitle: 'Pan especial', image: dgLogo },
  { category: 'postres', title: 'Pie de Limón', subtitle: 'Postre refrescante', image: dgLogo },
];

const filterCategories = [
  { id: 'all', label: 'Todos' },
  { id: 'tortas', label: 'Tortas' },
  { id: 'pan', label: 'Pan' },
  { id: 'pasteles', label: 'Pasteles' },
  { id: 'postres', label: 'Postres' },
];
---

<Layout 
	title="Galería - DGBACKERY&CAKE"
	description="Explora nuestra galería de creaciones. Tortas, panes y postres que hemos elaborado con amor para nuestros clientes."
>
	<Header />
	
	<main>
		<!-- Page Hero -->
		<section class="pt-32 lg:pt-40 pb-16 lg:pb-24 bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="max-w-3xl">
					<span class="category-label text-[#7c572e] mb-4 block">Portfolio</span>
					<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-semibold text-[#1e1b13] mb-6">
						Nuestras 
						<span class="text-[#b02c32]">Creaciones</span>
					</h1>
					<p class="text-lg text-[#50453b] leading-relaxed">
						Cada producto es una obra de arte hecha con dedicación. Descubre algunas de nuestras creaciones más especiales para nuestros clientes.
					</p>
				</div>
			</div>
		</section>

		<!-- Gallery Filter -->
		<section class="sticky top-20 lg:top-24 z-30 bg-[#fff8ef] border-b border-[#d4c4b7]/30">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="flex items-center gap-2 py-4 overflow-x-auto no-scrollbar" id="gallery-filters">
					{filterCategories.map((cat, index) => (
						<button
							class={`filter-btn whitespace-nowrap px-5 py-2.5 text-sm font-medium transition-all duration-300 ${index === 0 ? 'active' : ''}`}
							data-filter={cat.id}
						>
							{cat.label}
						</button>
					))}
				</div>
			</div>
		</section>

		<!-- Gallery Grid -->
		<section class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6" id="gallery-grid">
					{galleryItems.map((item, index) => (
						<div 
							class={`gallery-item group relative overflow-hidden cursor-pointer ${index === 0 || index === 4 ? 'row-span-2' : ''}`}
							data-category={item.category}
						>
							<Image 
								src={item.image} 
								alt={item.title}
								width={600}
								height={index === 0 || index === 4 ? 800 : 400}
								loading="lazy"
								class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
							/>
							
							<!-- Overlay -->
							<div class="absolute inset-0 bg-gradient-to-t from-[#1e1b13]/80 via-[#1e1b13]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
							
							<!-- Content -->
							<div class="absolute inset-0 flex flex-col justify-end p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
								<span class="category-label text-[#fecb98] mb-2">{item.category.charAt(0).toUpperCase() + item.category.slice(1)}</span>
								<h3 class="font-serif text-xl text-white mb-1">{item.title}</h3>
								<p class="text-white/80 text-sm">{item.subtitle}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 lg:py-32 bg-[#b02c32]">
			<div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
				<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-white mb-6">
					¿Te inspiraste?
				</h2>
				<p class="text-lg text-white/90 mb-10 max-w-2xl mx-auto">
					Estas son solo algunas de nuestras creaciones. Podemos hacer realidad tu idea perfecta.
				</p>
				<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" 
				   class="inline-flex items-center justify-center gap-3 px-10 py-5 text-lg font-semibold text-[#b02c32] bg-white rounded-sm shadow-2xl hover:shadow-3xl hover:scale-105 transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
					</svg>
					Hacer tu Pedido
				</a>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>

<style>
	.no-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}

	.filter-btn {
		border: 1px solid transparent;
		color: #50453b;
		border-radius: 0.125rem;
		background: transparent;
		cursor: pointer;
	}

	.filter-btn:hover {
		background: rgba(130, 117, 106, 0.1);
		border-color: #82756a;
		color: #1e1b13;
	}

	.filter-btn.active {
		background: #b02c32;
		color: white;
		border-color: #b02c32;
	}

	.gallery-item {
		aspect-ratio: 1;
	}

	.gallery-item.row-span-2 {
		aspect-ratio: auto;
		grid-row: span 2;
	}

	@media (max-width: 1024px) {
		.gallery-item.row-span-2 {
			grid-row: span 1;
			aspect-ratio: 1;
		}
	}
</style>

<script>
	const filterButtons = document.querySelectorAll('.filter-btn');
	const galleryItems = document.querySelectorAll('.gallery-item');

	filterButtons.forEach(button => {
		button.addEventListener('click', () => {
			const filter = button.getAttribute('data-filter');
			
			// Update active state
			filterButtons.forEach(btn => btn.classList.remove('active'));
			button.classList.add('active');
			
			// Filter items
			galleryItems.forEach(item => {
				const category = item.getAttribute('data-category');
				
				if (filter === 'all' || category === filter) {
					item.style.display = 'block';
					setTimeout(() => {
						item.style.opacity = '1';
						item.style.transform = 'scale(1)';
					}, 10);
				} else {
					item.style.opacity = '0';
					item.style.transform = 'scale(0.95)';
					setTimeout(() => {
						item.style.display = 'none';
					}, 300);
				}
			});
		});
	});
</script>
