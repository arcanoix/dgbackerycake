---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { Image } from 'astro:assets';
import dgLogo from '../assets/image/dg-logo.jpg';

const values = [
  { icon: 'heart', title: 'Pasión', description: 'Amamos lo que hacemos y se nota en cada detalle de nuestros productos.' },
  { icon: 'star', title: 'Calidad', description: 'Solo utilizamos ingredientes premium para garantizar el mejor sabor y frescura.' },
  { icon: 'palette', title: 'Creatividad', description: 'Cada pedido es único. Trabajamos contigo para crear diseños personalizados.' },
  { icon: 'handshake', title: 'Compromiso', description: 'Tu satisfacción es nuestra prioridad. Nos esforzamos por superar tus expectativas.' },
  { icon: 'leaf', title: 'Frescura', description: 'Elaboramos todo diariamente para garantizar productos frescos y deliciosos.' },
  { icon: 'users', title: 'Familia', description: 'Tratamos a cada cliente como parte de nuestra familia extendida.' },
];

const processSteps = [
  { number: '01', title: 'Consulta Personalizada', description: 'Escuchamos tus ideas y necesidades para entender exactamente lo que deseas.' },
  { number: '02', title: 'Selección de Ingredientes', description: 'Elegimos cuidadosamente los mejores ingredientes frescos y de calidad premium.' },
  { number: '03', title: 'Elaboración Artesanal', description: 'Preparamos cada producto con técnicas tradicionales y mucha dedicación.' },
  { number: '04', title: 'Decoración Creativa', description: 'Diseñamos y decoramos con atención al detalle para crear algo único.' },
  { number: '05', title: 'Control de Calidad', description: 'Verificamos que todo esté perfecto antes de la entrega.' },
  { number: '06', title: 'Entrega Puntual', description: 'Llevamos tu pedido fresco y en perfectas condiciones, justo a tiempo.' },
];

const icons = {
  heart: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  palette: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`,
  handshake: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 7.65l.77.78 7.65 7.65 7.65-7.65.77-.78a5.4 5.4 0 0 0 0-7.65z"/><path d="M12 5.36l-2.47 2.47"/><path d="M14.47 7.83l-2.47-2.47"/></svg>`,
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.77 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  users: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};
---

<Layout 
	title="Sobre Nosotros - DGBACKERY&CAKE"
	description="Conoce la historia detrás de DGBACKERY&CAKE. Pasión por la repostería artesanal y compromiso con la calidad desde el primer día."
>
	<Header />
	
	<main>
		<!-- Page Hero -->
		<section class="pt-32 lg:pt-40 pb-16 lg:pb-24 bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="max-w-3xl">
					<span class="category-label text-[#7c572e] mb-4 block">Nuestra Historia</span>
					<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-semibold text-[#1e1b13] mb-6">
						Más que una
						<span class="text-[#b02c32]">repostería</span>
					</h1>
					<p class="text-lg text-[#50453b] leading-relaxed">
						Somos una familia que comparte la pasión por crear momentos dulces e inolvidables. Cada producto lleva nuestra dedicación y amor.
					</p>
				</div>
			</div>
		</section>

		<!-- Story Section - Asymmetric Layout -->
		<section class="section-container bg-[#f5edde]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
					<!-- Image Column -->
					<div class="relative order-2 lg:order-1">
						<div class="relative">
							<!-- Decorative Frame -->
							<div class="absolute -inset-4 border border-[#b02c32]/20 -z-10"></div>
							<div class="absolute -inset-8 border border-[#fecb98]/40 -z-20 translate-x-4 translate-y-4"></div>
							
							<Image 
								src={dgLogo} 
								alt="DGBACKERY&CAKE - Nuestra Historia"
								width={600}
								height={600}
								loading="eager"
								class="w-full h-auto"
							/>
						</div>
					</div>
					
					<!-- Content Column -->
					<div class="order-1 lg:order-2">
						<span class="category-label text-[#7c572e] mb-4 block">¿Quiénes Somos?</span>
						<h2 class="font-serif text-3xl sm:text-4xl font-semibold text-[#1e1b13] mb-6">
							Una historia de pasión y dedicación
						</h2>
						<div class="space-y-4 text-[#50453b] leading-relaxed">
							<p>
								DGBACKERY&CAKE nació del amor por la repostería y el deseo de compartir momentos especiales con cada cliente. Lo que comenzó como un sueño en una pequeña cocina, hoy se ha convertido en un emprendimiento que endulza la vida de muchas familias.
							</p>
							<p>
								Cada producto que elaboramos lleva nuestra dedicación, pasión y el compromiso de usar solo los mejores ingredientes. Creemos que la repostería es un arte que conecta corazones y crea recuerdos inolvidables.
							</p>
							<p>
								Desde tortas personalizadas para celebraciones especiales hasta pan fresco para el desayuno diario, ponemos el mismo amor y cuidado en cada creación. Tu satisfacción es nuestra mayor recompensa.
							</p>
						</div>
						
						<!-- Stats -->
						<div class="mt-10 pt-8 border-t border-[#d4c4b7]/30">
							<div class="grid grid-cols-3 gap-8">
								<div>
									<div class="text-3xl font-serif font-semibold text-[#b02c32]">5+</div>
									<div class="text-sm text-[#50453b]">Años de Experiencia</div>
								</div>
								<div>
									<div class="text-3xl font-serif font-semibold text-[#b02c32]">500+</div>
									<div class="text-sm text-[#50453b]">Pedidos Entregados</div>
								</div>
								<div>
									<div class="text-3xl font-serif font-semibold text-[#b02c32]">100%</div>
									<div class="text-sm text-[#50453b]">Clientes Felices</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Values Section -->
		<section class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="text-center mb-16">
					<span class="category-label text-[#7c572e] mb-4 block">Nuestros Valores</span>
					<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-[#1e1b13]">
						Lo que nos <span class="text-[#b02c32]">define</span>
					</h2>
				</div>
				
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{values.map((value) => (
						<div class="group p-8 bg-[#f5edde] border border-[#d4c4b7]/20 transition-all duration-500 hover:shadow-xl">
							<div class="mb-5 text-[#b02c32] transition-transform duration-500 group-hover:scale-110" set:html={icons[value.icon]} />
							<h3 class="font-serif text-xl font-semibold text-[#1e1b13] mb-3">{value.title}</h3>
							<p class="text-[#50453b] leading-relaxed text-sm">{value.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Mission & Vision -->
		<section class="section-container bg-[#1e1b13]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="grid md:grid-cols-2 gap-8 lg:gap-12">
					<div class="p-8 lg:p-12 bg-[#343026] border border-[#50453b]/30">
						<span class="category-label text-[#fecb98] mb-4 block">Misión</span>
						<h3 class="font-serif text-2xl lg:text-3xl font-semibold text-white mb-4">
							Nuestro Propósito
						</h3>
						<p class="text-[#d4c4b7] leading-relaxed">
							Crear productos de repostería artesanal de la más alta calidad, elaborados con amor y dedicación, para hacer de cada celebración un momento especial e inolvidable.
						</p>
					</div>
					
					<div class="p-8 lg:p-12 bg-[#b02c32] border border-[#b02c32]">
						<span class="category-label text-white/80 mb-4 block">Visión</span>
						<h3 class="font-serif text-2xl lg:text-3xl font-semibold text-white mb-4">
							Hacia dónde vamos
						</h3>
						<p class="text-white/90 leading-relaxed">
							Ser la repostería preferida de la comunidad, reconocida por la excelencia de nuestros productos, la creatividad en nuestros diseños y el cariño con el que tratamos a cada cliente.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Process Section -->
		<section class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="text-center mb-16">
					<span class="category-label text-[#7c572e] mb-4 block">Nuestro Proceso</span>
					<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-[#1e1b13] mb-4">
						De la idea a tu <span class="text-[#b02c32]">mesa</span>
					</h2>
					<p class="text-[#50453b] max-w-2xl mx-auto">
						Cada producto pasa por un cuidadoso proceso para garantizar la máxima calidad
					</p>
				</div>
				
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{processSteps.map((step) => (
						<div class="group relative p-8 bg-white border border-[#d4c4b7]/20 transition-all duration-500 hover:shadow-xl hover:-translate-y-1">
							<div class="absolute top-6 right-6 text-5xl font-serif font-bold text-[#d4c4b7]/30">{step.number}</div>
							<h3 class="font-serif text-xl font-semibold text-[#1e1b13] mb-3 relative z-10">{step.title}</h3>
							<p class="text-[#50453b] leading-relaxed text-sm relative z-10">{step.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="py-24 lg:py-32 bg-[#b02c32]">
			<div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 text-center">
				<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-white mb-6">
					¿Quieres ser parte de nuestra historia?
				</h2>
				<p class="text-lg text-white/90 mb-10 max-w-2xl mx-auto">
					Nos encantaría endulzar tu próxima celebración. Contáctanos y cuéntanos qué tienes en mente.
				</p>
				<a href="/contacto" class="inline-flex items-center justify-center gap-3 px-10 py-5 text-lg font-semibold text-[#b02c32] bg-white rounded-sm shadow-2xl hover:shadow-3xl hover:scale-105 transition-all duration-300">
					Contáctanos
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 12h14M12 5l7 7-7 7"/>
					</svg>
				</a>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>
