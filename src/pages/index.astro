---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { Image } from 'astro:assets';
import dgLogo from '../assets/image/dg-logo.jpg';
---

<Layout>
	<Header />
	
	<main>
		<!-- Hero Section: The First Impression -->
		<Hero />
		
		<!-- Editorial Features: Why Choose Us -->
		<section class="editorial-spacing bg-[#f5edde] relative">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<!-- Section Subtitle -->
				<div class="text-center mb-16">
					<div class="category-label text-[#b02c32] mb-4">El Secreto de Nuestro Sabor</div>
					<h2 class="font-serif text-4xl sm:text-5xl font-bold text-[#1e1b13]">Artesanía en Cada <span class="text-[#b02c32]">Detalle</span></h2>
				</div>
				
				<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
					<FeatureCard 
						icon="cake"
						title="Diseño Exclusivo"
						description="Cada torta es una pieza única, diseñada para capturar la esencia de tu celebración."
					/>
					<FeatureCard 
						icon="bread"
						title="Masa Madre"
						description="Nuestro pan se hornea diariamente con procesos lentos para garantizar salud y sabor."
					/>
					<FeatureCard 
						icon="quality"
						title="Ingredientes Puros"
						description="Solo utilizamos mantequilla real, chocolate belga y vainas de vainilla auténticas."
					/>
					<FeatureCard 
						icon="delivery"
						title="Entrega Cuidadosa"
						description="Tus creaciones llegan impecables y frescas a tu puerta, justo a tiempo."
					/>
				</div>
			</div>
		</section>

		<!-- Featured Masterpieces: The Gallery -->
		<section class="editorial-spacing bg-[#fff8ef] overflow-hidden">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<!-- Editorial Header: Asymmetric & Modern -->
				<div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-20">
					<div class="lg:max-w-2xl">
						<span class="category-label text-[#7c572e] mb-6 block tracking-[0.3em]">Signature Collection</span>
						<h2 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold text-[#1e1b13] leading-tight">
							Nuestras <span class="italic font-normal">Obras Maestras</span> <br/> 
							<span class="text-[#b02c32]">Más Deseadas</span>
						</h2>
					</div>
					<div class="lg:max-w-sm">
						<p class="text-lg text-[#50453b] opacity-80 border-l-4 border-[#b02c32]/20 pl-6 lg:text-right italic">
							"La repostería es un arte que se come, cada bocado debe contar una historia de pasión."
						</p>
					</div>
				</div>
				
				<!-- Featured Grid: Large & Focused -->
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12">
					<ProductCard 
						title="Torta Royale de Chocolate"
						description="Siete capas de chocolate belga, ganache de avellana y un acabado en 'drip' dorado floral."
						image={dgLogo}
						category="Tortas de Lujo"
						price="$55.00"
					/>
					<ProductCard 
						title="Pan Rustique de Masa Madre"
						description="Corteza crujiente, miga aireada y el aroma inconfundible del trigo fermentado al natural."
						image={dgLogo}
						category="Panadería Fina"
						price="$12.00"
					/>
					<ProductCard 
						title="Cupcakes de Terciopelo"
						description="Suaves cupcakes de vainilla francesa con frosting de crema de queso y flores naturales comestibles."
						image={dgLogo}
						category="Bocados Sweetify"
						price="$28.00 / docena"
					/>
				</div>
				
				<!-- Editorial CTA Link -->
				<div class="mt-20 text-center">
					<a href="/productos" class="group inline-flex items-center gap-4 text-[#1e1b13] font-bold text-lg tracking-widest uppercase hover:text-[#b02c32] transition-colors">
						<span class="border-b-2 border-[#1e1b13] group-hover:border-[#b02c32] transition-colors pb-1">Descubrir Menú Completo</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-2 transition-transform">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Testimonials: Warm & Trustworthy -->
		<section class="editorial-spacing bg-white">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="flex flex-col items-center mb-16">
					<span class="category-label text-[#7c572e] mb-4">Experiencias</span>
					<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1e1b13] text-center">
						Lo que <span class="text-[#b02c32]">Nuestros Clientes</span> Dicen
					</h2>
				</div>
				
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
					<TestimonialCard 
						name="María González"
						text="La torta para el aniversario fue un sueño. No solo era hermosa por fuera, el sabor era de otro mundo. ¡Gracias por hacer el momento mágico!"
						rating={5}
						service="Torta Personalizada"
					/>
					<TestimonialCard 
						name="Carlos Rodríguez"
						text="No he vuelto a comprar pan de supermercado. La masa madre de DGBACKERY es adictiva y se nota la calidad en cada rebanada."
						rating={5}
						service="Suscripción de Pan"
					/>
					<TestimonialCard 
						name="Ana Martínez"
						text="Los cupcakes para la boda fueron la sensación. Delicados, sofisticados y llegaron perfectos. ¡El servicio es impecable!"
						rating={5}
						service="Evento Especial"
					/>
				</div>
			</div>
		</section>

		<!-- Final Invitation: The Connection -->
		<section class="relative py-32 lg:py-48 bg-[#1e1b13] overflow-hidden">
			<!-- Organic Pattern Overlay -->
			<div class="absolute inset-0 opacity-[0.03] pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/pinstriped-suit.png')]"></div>
			
			<div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 text-center relative z-10">
				<span class="text-white/60 tracking-[0.4em] uppercase text-[0.65rem] mb-8 block font-bold">Reserva tu Creación</span>
				<h2 class="font-serif text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-10 leading-tight">
					Hagamos que tu Próximo Evento sea <span class="italic font-normal text-[#ffcc99]">Inolvidable</span>.
				</h2>
				<p class="text-xl lg:text-2xl text-white/70 mb-12 max-w-2xl mx-auto leading-relaxed">
					¿Tienes una idea en mente? Escríbenos directamente por WhatsApp y diseñemos juntos el centro de mesa perfecto para tu celebración.
				</p>
				<div class="flex flex-col sm:flex-row gap-6 justify-center">
					<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" 
					   class="inline-flex items-center justify-center gap-3 px-12 py-6 text-lg font-bold text-[#1e1b13] bg-[#ffcc99] rounded-full shadow-2xl hover:bg-white hover:scale-105 transition-all duration-500">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
						Contactar WhatsApp
					</a>
					<a href="/nosotros" class="inline-flex items-center justify-center gap-3 px-12 py-6 text-lg font-bold text-white border-2 border-white/20 rounded-full hover:bg-white/10 hover:border-white transition-all duration-500">
						Nuestra Historia
					</a>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>
