---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { Image } from 'astro:assets';
import dgLogo from '../assets/image/dg-logo.jpg';
---

<Layout>
	<Header />
	
	<main>
		<!-- Hero Section -->
		<Hero />
		
		<!-- Features Section - Editorial Style -->
		<section class="section-container bg-[#f5edde]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
					<FeatureCard 
						icon="cake"
						title="Tortas Personalizadas"
						description="Diseños únicos adaptados a tu celebración especial, elaborados con dedicación"
					/>
					<FeatureCard 
						icon="bread"
						title="Pan Artesanal"
						description="Fresco todos los días, horneado con masa madre y ingredientes naturales"
					/>
					<FeatureCard 
						icon="quality"
						title="Calidad Premium"
						description="Seleccionamos los mejores ingredientes para garantizar el mejor sabor"
					/>
					<FeatureCard 
						icon="delivery"
						title="Entrega a Domicilio"
						description="Llevamos tus pedidos frescos hasta tu puerta con cuidado y puntualidad"
					/>
				</div>
			</div>
		</section>

		<!-- Featured Products - Editorial Layout -->
		<section class="section-container bg-[#fff8ef]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<!-- Section Header with Asymmetric Layout -->
				<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
					<div class="lg:max-w-xl">
						<span class="category-label text-[#7c572e] mb-4 block">Nuestras Creaciones</span>
						<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-[#1e1b13]">
							Productos <span class="text-[#b02c32]">Destacados</span>
						</h2>
					</div>
					<p class="text-[#50453b] text-lg lg:text-right lg:max-w-md">
						Cada creación es elaborada artesanalmente con los mejores ingredientes y mucho amor
					</p>
				</div>
				
				<!-- Products Grid -->
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
					<ProductCard 
						title="Torta de Chocolate"
						description="Deliciosa torta de chocolate belga con relleno de ganache y cobertura de crema de mantequilla"
						image={dgLogo}
						category="Tortas"
						price="Desde $45"
					/>
					<ProductCard 
						title="Pan Artesanal"
						description="Pan fresco horneado diariamente con masa madre y harina de trigo orgánico"
						image={dgLogo}
						category="Panadería"
						price="Desde $8"
					/>
					<ProductCard 
						title="Cupcakes Personalizados"
						description="Cupcakes decorados artesanalmente para tu evento, disponibles en múltiples sabores"
						image={dgLogo}
						category="Postres"
						price="Desde $25/dz"
					/>
				</div>
				
				<!-- View All CTA -->
				<div class="mt-16 text-center">
					<a href="/productos" class="btn-secondary">
						Ver Todos los Productos
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 inline">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Testimonials - Warm Background -->
		<section class="section-container bg-[#efe7d9]">
			<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
				<div class="text-center mb-16">
					<span class="category-label text-[#7c572e] mb-4 block">Testimonios</span>
					<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-semibold text-[#1e1b13]">
						Lo que dicen nuestros <span class="text-[#b02c32]">clientes</span>
					</h2>
				</div>
				
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					<TestimonialCard 
						name="María González"
						text="La torta de cumpleaños que pedí superó todas mis expectativas. Deliciosa, hermosa y el servicio fue impecable. ¡Todos quedaron encantados!"
						rating={5}
						service="Torta de Cumpleaños"
					/>
					<TestimonialCard 
						name="Carlos Rodríguez"
						text="El pan artesanal es simplemente increíble. Fresco, con un sabor único y textura perfecta. Ahora es parte indispensable de mi desayuno diario."
						rating={5}
						service="Pan Artesanal"
					/>
					<TestimonialCard 
						name="Ana Martínez"
						text="Los cupcakes para mi boda fueron perfectos. La atención, la presentación y el sabor fueron excepcionales. Altamente recomendado."
						rating={5}
						service="Cupcakes para Boda"
					/>
				</div>
			</div>
		</section>

		<!-- CTA Section - Bold Statement -->
		<section class="relative py-24 lg:py-32 bg-[#b02c32] overflow-hidden">
			<!-- Decorative Pattern -->
			<div class="absolute inset-0 opacity-5" style="background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="1"%3E%3Cpath d="M36 34c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4zm0-10c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4zm10 10c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4zm0-10c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');""></div>
			
			<div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 text-center relative z-10">
				<h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-semibold text-white mb-6">
					¿Listo para hacer tu pedido?
				</h2>
				<p class="text-lg lg:text-xl text-white/90 mb-10 max-w-2xl mx-auto">
					Contáctanos y cuéntanos qué necesitas. Estamos aquí para hacer realidad tus ideas y endulzar tus momentos especiales.
				</p>
				<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" 
				   class="inline-flex items-center justify-center gap-3 px-10 py-5 text-lg font-semibold text-[#b02c32] bg-white rounded-sm shadow-2xl hover:shadow-3xl hover:scale-105 transition-all duration-300">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
				</svg>
					Contactar Ahora
				</a>
			</div>
		</section>
	</main>
	
	<Footer />
	<WhatsAppFloat />
</Layout>
