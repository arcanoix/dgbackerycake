					<li><a href="/" class="text-[#d4c4b7] hover:text-white transition-colors text-sm">Inicio</a></li>
					<li><a href="/productos" class="text-[#d4c4b7] hover:text-white transition-colors text-sm">Productos</a></li>
					<li><a href="/galeria" class="text-[#d4c4b7] hover:text-white transition-colors text-sm">Galería</a></li>
					<li><a href="/nosotros" class="text-[#d4c4b7] hover:text-white transition-colors text-sm">Nosotros</a></li>
					<li><a href="/contacto" class="text-[#d4c4b7] hover:text-white transition-colors text-sm">Contacto</a></li>
				</ul>
			</div>
			
			<!-- Products -->
			<div>
				<h4 class="font-serif text-lg font-semibold mb-6">Productos</h4>
