					</li>
					<li class="flex items-start gap-3 text-[#d4c4b7] text-sm">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#b02c32] flex-shrink-0 mt-0.5">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
							<polyline points="22,6 12,13 2,6"></polyline>
						</svg>
						<span>dgbakerycake@gmail.com</span>
					</li>
				</ul>
				
				<div class="mt-6 pt-6 border-t border-[#343026]">
					<h5 class="text-sm font-semibold mb-3">Horario de Atención</h5>
