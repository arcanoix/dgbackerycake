---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white mt-20">
	<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16">
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
			<!-- Brand Section -->
			<div class="space-y-6">
				<h3 class="text-3xl font-display font-bold">
					DGBACKERY<span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">&CAKE</span>
				</h3>
				<p class="text-gray-300 leading-relaxed">
					Repostería artesanal hecha con amor y dedicación. Hacemos realidad tus momentos especiales.
				</p>
				<div class="flex gap-4">
					<a href="https://www.facebook.com/profile.php?id=100090394729895" target="_blank" rel="noopener noreferrer" 
					   class="w-12 h-12 flex items-center justify-center bg-gradient-to-br from-blue-600 to-blue-500 rounded-xl hover:scale-110 transform transition-all duration-300 shadow-lg hover:shadow-xl"
					   aria-label="Facebook">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
						</svg>
					</a>
					<a href="https://www.instagram.com/dgbackerycake" target="_blank" rel="noopener noreferrer" 
					   class="w-12 h-12 flex items-center justify-center bg-gradient-to-br from-purple-600 to-pink-600 rounded-xl hover:scale-110 transform transition-all duration-300 shadow-lg hover:shadow-xl"
					   aria-label="Instagram">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
							<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
							<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
						</svg>
					</a>
					<a href="https://www.tiktok.com/@dgbackerycake" target="_blank" rel="noopener noreferrer" 
					   class="w-12 h-12 flex items-center justify-center bg-gradient-to-br from-gray-900 to-gray-700 rounded-xl hover:scale-110 transform transition-all duration-300 shadow-lg hover:shadow-xl"
					   aria-label="TikTok">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path>
						</svg>
					</a>
					<a href="https://wa.me/584128477968" target="_blank" rel="noopener noreferrer" 
					   class="w-12 h-12 flex items-center justify-center bg-gradient-to-br from-green-600 to-green-500 rounded-xl hover:scale-110 transform transition-all duration-300 shadow-lg hover:shadow-xl"
					   aria-label="WhatsApp">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
					</a>
				</div>
			</div>
			
			<!-- Navigation -->
			<div class="space-y-6">
				<h4 class="text-xl font-semibold text-white">Navegación</h4>
				<ul class="space-y-3">
					<li>
						<a href="/" class="text-gray-300 hover:text-secondary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-secondary group-hover:w-4 transition-all duration-200"></span>
							Inicio
						</a>
					</li>
					<li>
						<a href="/productos" class="text-gray-300 hover:text-secondary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-secondary group-hover:w-4 transition-all duration-200"></span>
							Productos
						</a>
					</li>
					<li>
						<a href="/galeria" class="text-gray-300 hover:text-secondary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-secondary group-hover:w-4 transition-all duration-200"></span>
							Galería
						</a>
					</li>
					<li>
						<a href="/nosotros" class="text-gray-300 hover:text-secondary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-secondary group-hover:w-4 transition-all duration-200"></span>
							Nosotros
						</a>
					</li>
					<li>
						<a href="/contacto" class="text-gray-300 hover:text-secondary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-secondary group-hover:w-4 transition-all duration-200"></span>
							Contacto
						</a>
					</li>
				</ul>
			</div>
			
			<!-- Products -->
			<div class="space-y-6">
				<h4 class="text-xl font-semibold text-white">Productos</h4>
				<ul class="space-y-3">
					<li>
						<a href="/productos#tortas" class="text-gray-300 hover:text-primary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-primary group-hover:w-4 transition-all duration-200"></span>
							Tortas Personalizadas
						</a>
					</li>
					<li>
						<a href="/productos#pan" class="text-gray-300 hover:text-primary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-primary group-hover:w-4 transition-all duration-200"></span>
							Pan Artesanal
						</a>
					</li>
					<li>
						<a href="/productos#pasteles" class="text-gray-300 hover:text-primary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-primary group-hover:w-4 transition-all duration-200"></span>
							Pasteles
						</a>
					</li>
					<li>
						<a href="/productos#postres" class="text-gray-300 hover:text-primary transition-colors duration-200 flex items-center gap-2 group">
							<span class="w-0 h-0.5 bg-primary group-hover:w-4 transition-all duration-200"></span>
							Postres
						</a>
					</li>
				</ul>
			</div>
			
			<!-- Contact -->
			<div class="space-y-6">
				<h4 class="text-xl font-semibold text-white">Contacto</h4>
				<ul class="space-y-4">
					<li class="flex items-start gap-3 text-gray-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400 flex-shrink-0 mt-1">
							<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
						</svg>
						<span>+58 412-8477968</span>
					</li>
					<li class="flex items-start gap-3 text-gray-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-400 flex-shrink-0 mt-1">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
							<polyline points="22,6 12,13 2,6"></polyline>
						</svg>
						<span>dgbakerycake@gmail.com</span>
					</li>
				</ul>
				
				<div class="pt-4">
					<h5 class="text-sm font-semibold text-white mb-3">⏰ Horario</h5>
					<div class="space-y-2 text-sm text-gray-300">
						<div class="flex justify-between">
							<span>Lun - Vie</span>
							<span class="text-gray-400">8:00 AM - 6:00 PM</span>
						</div>
						<div class="flex justify-between">
							<span>Sábado</span>
							<span class="text-gray-400">9:00 AM - 5:00 PM</span>
						</div>
						<div class="flex justify-between">
							<span>Domingo</span>
							<span class="text-gray-400">Cerrado</span>
						</div>
					</div>
				</div>
			</div>
		</div>
		
		<!-- Bottom Bar -->
		<div class="border-t border-gray-700 pt-8 mt-8">
			<div class="flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
				<p class="text-gray-400 text-sm">
					&copy; {currentYear} DGBACKERY&CAKE. Todos los derechos reservados.
				</p>
				<p class="text-gray-400 text-sm flex items-center gap-2">
					Hecho con <span class="text-secondary animate-pulse">❤️</span> para endulzar tu día
				</p>
			</div>
		</div>
	</div>
</footer>
