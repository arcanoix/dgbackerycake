---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  category?: string;
  price?: string;
}

const { title, description, image, category, price } = Astro.props;
---

<div class="group bg-[#fff8ef] overflow-hidden transition-all duration-500 hover:shadow-2xl">
  <div class="relative overflow-hidden aspect-[4/3]">
    <Image 
      src={image} 
      alt={title}
      width={600}
      height={450}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
    {category && (
      <span class="absolute top-4 left-4 px-3 py-1 text-xs font-semibold tracking-wider uppercase bg-[#fff8ef] text-[#7c572e]">
        {category}
      </span>
    )}
    
    {/* Hover Overlay */}
    <div class="absolute inset-0 bg-[#1e1b13]/60 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
      <a 
        href="https://wa.me/584128477968" 
        target="_blank" 
        rel="noopener noreferrer"
        class="px-6 py-3 bg-white text-[#b02c32] font-semibold text-sm tracking-wide transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500"
      >
        Ver Detalles
      </a>
    </div>
  </div>
  
  <div class="p-6">
    <h3 class="font-serif text-xl font-semibold text-[#1e1b13] mb-2">{title}</h3>
    <p class="text-[#50453b] text-sm leading-relaxed mb-4 line-clamp-2">{description}</p>
    
    <div class="flex items-center justify-between pt-4 border-t border-[#d4c4b7]/30">
      {price && (
        <span class="text-[#b02c32] font-semibold text-lg">{price}</span>
      )}
      <a 
        href="https://wa.me/584128477968" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium text-[#7c572e] hover:text-[#b02c32] transition-colors"
      >
        Ordenar
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</div>
