---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: any; // Allow for dynamic Image import or regular string paths if needed, though ImageMetadata is standard
  category?: string;
  price?: string;
}

const { title, description, image, category, price } = Astro.props;
---

<div class="group relative bg-white/40 backdrop-blur-sm rounded-3xl overflow-hidden transition-all duration-700 hover:shadow-2xl hover:-translate-y-2 border border-white/40">
  <div class="relative overflow-hidden aspect-[4/5]">
    <Image 
      src={image} 
      alt={title}
      width={600}
      height={750}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
    />
    
    <!-- Category Badge (Glass) -->
    {category && (
      <span class="absolute top-6 left-6 px-4 py-1.5 text-[0.65rem] font-bold tracking-widest uppercase bg-white/60 backdrop-blur-md border border-white/40 text-[#7c572e] rounded-full z-10">
        {category}
      </span>
    )}
    
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#1e1b13]/80 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-700"></div>

    <div class="absolute bottom-0 left-0 right-0 p-8 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
      <div class="flex items-center justify-between mb-4">
        {price && (
          <span class="text-white font-bold text-2xl drop-shadow-md">{price}</span>
        )}
      </div>
      <a 
        href="https://wa.me/584128477968" 
        target="_blank" 
        rel="noopener noreferrer"
        class="w-full inline-flex items-center justify-center gap-2 px-6 py-4 bg-white text-[#1e1b13] font-bold text-sm uppercase tracking-widest rounded-full opacity-0 group-hover:opacity-100 transition-all duration-700 shadow-xl"
      >
        Pedir vía WhatsApp
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
  
  <div class="p-8 pb-10">
    <h3 class="font-serif text-2xl font-bold text-[#1e1b13] mb-3 group-hover:text-[#b02c32] transition-colors">{title}</h3>
    <p class="text-[#50453b] text-base leading-relaxed opacity-80">{description}</p>
  </div>
</div>
