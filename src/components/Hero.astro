---
import { Image } from 'astro:assets';
import dgLogo from '../assets/image/dg-logo.jpg';
---

<section class="relative min-h-screen bg-[#fff8ef] overflow-hidden">
	<!-- Subtle Background Texture -->
	<div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%231e1b13" fill-opacity="1"%3E%3Cpath d="M36 34c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4zm0-10c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4zm10 10c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4zm0-10c0-2.21-1.79-4-4-4s-4 1.79-4 4 1.79 4 4 4 4-1.79 4-4z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
	
	<!-- Decorative Elements -->
	<div class="absolute top-20 right-10 w-32 h-32 rounded-full bg-[#ffc8c5]/20 blur-3xl"></div>
	<div class="absolute bottom-40 left-10 w-40 h-40 rounded-full bg-[#fecb98]/30 blur-3xl"></div>
	
	<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 pt-32 lg:pt-40">
		<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
			
			<!-- Content Column - Offset to create asymmetry -->
			<div class="relative lg:pr-8">
				<!-- Category Label -->
				<div class="mb-6">
					<span class="category-label text-[#7c572e]">Repostería Artesanal</span>
				</div>
				
				<!-- Editorial Headline -->
				<h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-semibold leading-[1.1] text-[#1e1b13] mb-6">
					Creamos
					<span class="block mt-2 text-[#b02c32]">momentos</span					<span class="block mt-2">inigualables</span>
				</h1>
				
				<!-- Elegant Description -->
				<p class="text-lg lg:text-xl text-[#50453b] leading-relaxed max-w-lg mb-8">
					Tortas personalizadas, pan artesanal y postres elaborados con dedicación. Cada creación es una obra de arte que transforma tus celebraciones en recuerdos inolvidables.
				</p>
				
				<!-- CTA Buttons -->
				<div class="flex flex-col sm:flex-row gap-4">
					<a 
						href="/productos" 
						class="btn-primary text-center"
					>
						Explorar Productos
					</a>
					<a 
						href="https://wa.me/584128477968"
						target="_blank"
						rel="noopener noreferrer"
						class="btn-secondary text-center"
					>
						<span class="flex items-center justify-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
							</svg>
							Consultar
						</span>
					</a>
				</div>
				
				<!-- Trust Indicators -->
				<div class="mt-12 pt-8 border-t border-[#d4c4b7]/30">
					<div class="flex items-center gap-8">
						<div>
							<div class="text-3xl font-serif font-semibold text-[#1e1b13]">5+</div>
							<div class="text-sm text-[#50453b]">Años de Experiencia</div>
						</div>
						<div class="w-px h-12 bg-[#d4c4b7]/50"></div>
						<div>
							<div class="text-3xl font-serif font-semibold text-[#1e1b13]">500+</div>
							<div class="text-sm text-[#50453b]">Pedidos Entregados</div>
						</div>
						<div class="w-px h-12 bg-[#d4c4b7]/50 hidden sm:block"></div>
						<div class="hidden sm:block">
							<div class="text-3xl font-serif font-semibold text-[#1e1b13]">100%</div>
							<div class="text-sm text-[#50453b]">Clientes Satisfechos</div>
						</div>
					</div>
				</div>
			</div>
			
			<!-- Image Column - Asymmetric positioning -->
			<div class="relative lg:pl-8">
				<div class="relative">
					<!-- Decorative Frame -->
					<div class="absolute -inset-4 border border-[#b02c32]/20 -z-10"></div>
					<div class="absolute -inset-8 border border-[#fecb98]/40 -z-20 translate-x-4 translate-y-4"></div>
					
					<!-- Main Image Container -->
					<div class="relative overflow-hidden">
						<Image 
							src={dgLogo} 
							alt="DGBACKERY&CAKE - Tortas artesanales de calidad" 
							width={600}
							height={600}
							loading="eager"
							fetchpriority="high"
							class="w-full h-auto object-cover transition-transform duration-700 hover:scale-105"
						/>
						
						<!-- Floating Badge -->
						<div class="absolute bottom-6 left-6 bg-white/95 backdrop-blur-sm px-4 py-3 shadow-lg">
							<div class="flex items-center gap-3">
								<div class="w-10 h-10 rounded-full bg-[#ffc8c5]/50 flex items-center justify-center">
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#b02c32">
										<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
									</svg>
								</div>
								<div>
									<div class="font-semibold text-sm text-[#1e1b13]">Artesanal 100%</div>
									<div class="text-xs text-[#50453b]">Ingredientes Premium</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		
		<!-- Scroll Indicator -->
		<div class="hidden lg:flex justify-center mt-20">
			<div class="flex flex-col items-center gap-2 text-[#50453b]">
				<span class="text-xs tracking-widest uppercase">Descubrir</span>
				<div class="w-px h-8 bg-[#50453b]/30 animate-pulse"></div>
			</div>
		</div>
	</div>
</section>
