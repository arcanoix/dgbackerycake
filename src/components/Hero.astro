---
import { Image } from 'astro:assets';
import heroCake from '../assets/image/hero-cake.png';
---

<section class="relative min-h-screen bg-gradient-to-br from-[#fff8ef] via-[#f8eef0] to-[#f5edde] overflow-hidden flex items-center">
	<!-- Decorative Flourish -->
	<div class="absolute top-20 right-[10%] w-[400px] h-[400px] rounded-full bg-[#ffc8c5]/30 blur-[100px] -z-10 animate-pulse"></div>
	<div class="absolute bottom-20 left-[5%] w-[300px] h-[300px] rounded-full bg-[#fecb98]/40 blur-[80px] -z-10"></div>
	
	<div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 w-full pt-20 lg:pt-0">
		<div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
			
			<!-- Left Content: Editorial & Bold -->
			<div class="relative z-10 lg:pr-12 text-center lg:text-left">
				<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/40 backdrop-blur-md border border-white/40 mb-8 mx-auto lg:mx-0">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#b02c32">
						<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
					</svg>
					<span class="text-[0.65rem] font-bold tracking-[0.2em] uppercase text-[#7c572e]">Creamos Momentos Especiales</span>
				</div>
				
				<h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-bold leading-[1.05] text-[#1e1b13] mb-8">
					Tortas Únicas,<br/>
					<span class="text-[#b02c32]">Hechas</span> con<br/>
					Dedicación
				</h1>
				
				<p class="text-lg lg:text-xl text-[#50453b] leading-relaxed max-w-lg mb-10 mx-auto lg:mx-0">
					Disfruta de nuestra repostería artesanal elaborada con los mejores ingredientes. Perfectas para cumpleaños, bodas o cualquier momento especial. Siente la diferencia en cada bocado.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-5 justify-center lg:justify-start">
					<a href="/productos" class="px-10 py-5 bg-[#1e1b13] text-white rounded-full font-bold text-lg hover:scale-105 transition-all shadow-xl hover:shadow-black/20">
						Pedir Ahora
					</a>
					<a href="/galeria" class="px-10 py-5 bg-white/40 backdrop-blur-md border border-[#1e1b13]/10 text-[#1e1b13] rounded-full font-bold text-lg hover:bg-white/60 transition-all">
						Ver Galería
					</a>
				</div>
				
				<!-- Highlights -->
				<div class="mt-16 flex items-center justify-center lg:justify-start gap-12 text-[#50453b]">
					<div class="text-center lg:text-left">
						<span class="block text-2xl font-serif font-bold text-[#1e1b13]">[ Deliciosa ]</span>
						<span class="text-xs uppercase tracking-widest opacity-60">Perfección</span>
					</div>
					<div class="text-center lg:text-left">
						<span class="block text-2xl font-serif font-bold text-[#1e1b13]">[ Creada ]</span>
						<span class="text-xs uppercase tracking-widest opacity-60">con Amor</span>
					</div>
				</div>
			</div>
			
			<!-- Right Content: The Masterpiece Image -->
			<div class="relative lg:-mr-12 scale-110 lg:scale-125 pointer-events-none">
				<div class="relative">
					<!-- Soft radial glow behind cake -->
					<div class="absolute inset-0 bg-radial from-[#ffc8c5]/40 to-transparent blur-3xl opacity-50 scale-75"></div>
					
					<Image 
						src={heroCake} 
						alt="Signature Cake de DGBACKERY&CAKE" 
						width={800}
						height={800}
						loading="eager"
						fetchpriority="high"
						class="w-full h-auto drop-shadow-[0_35px_35px_rgba(0,0,0,0.15)] animate-float"
					/>
				</div>
			</div>
		</div>
		
		<!-- Scroll Indicator -->
		<div class="hidden lg:flex justify-center mt-20">
			<div class="flex flex-col items-center gap-2 text-[#50453b]">
				<span class="text-xs tracking-widest uppercase">Descubrir</span>
				<div class="w-px h-8 bg-[#50453b]/30 animate-pulse"></div>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-20px); }
	}
	.animate-float {
		animation: float 6s ease-in-out infinite;
	}
</style>
