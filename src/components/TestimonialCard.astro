---
interface Props {
  name: string;
  text: string;
  rating?: number;
  service?: string;
}

const { name, text, rating = 5, service } = Astro.props;
---

<div class="bg-[#fff8ef] p-6 lg:p-8 border border-[#d4c4b7]/20">
  <!-- Quote Icon -->
  <div class="mb-4 text-[#b02c32]/30">
    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
  </div>
  
  <!-- Review Text -->
  <p class="text-[#50453b] leading-relaxed mb-6 italic">"{text}"</p>
  
  <!-- Rating -->
  <div class="flex gap-1 mb-4">
    {Array.from({ length: rating }).map(() => (
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#b02c32">
        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
      </svg>
    ))}
  </div>
  
  <!-- Author Info -->
  <div class="pt-4 border-t border-[#d4c4b7]/30">
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-[#ffc8c5]/50 flex items-center justify-center text-[#b02c32] font-serif font-semibold text-lg">
        {name.charAt(0)}
      </div>
      <div>
        <h4 class="font-serif font-semibold text-[#1e1b13]">{name}</h4>
        {service && (
          <span class="text-sm text-[#50453b]">{service}</span>
        )}
      </div>
    </div>
  </div>
</div>
